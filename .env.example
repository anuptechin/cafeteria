# Local Postgres (dedicated app user)
DATABASE_URL=postgres://canteen_app:CHANGE_ME@localhost:5432/canteen
PGHOST=localhost
PGPORT=5432
PGUSER=canteen_app
PGPASSWORD=CHANGE_ME
PGDATABASE=canteen
PORT=4000
APP_TZ=Asia/Kolkata

# Auth — session signing key + super admin bootstrap (super admin can never be deleted)
JWT_SECRET=replace-with-a-long-random-string
SUPER_ADMIN_USER=ambuj.kumar@ddecor.com
SUPER_ADMIN_NAME=Ambuj Kumar
SUPER_ADMIN_PASSWORD=CHANGE_ME

# --- Docker Compose only (containers talk over the internal 'db' network) ---
# DB host is 'db' (compose service name); URL-encode special chars in the password (@ -> %40).
COMPOSE_DATABASE_URL=postgres://canteen_app:CHANGE_ME@db:5432/canteen

# Host directory of HikCentral face photos ("<name>+_<emp_id>.jpg"), mounted
# read-only into the API and served by /faces/:id. Default ./faces (relative to
# the compose dir). On prod this resolves to /data/cafeteria/faces.
FACES_DIR_HOST=./faces

# --- Prod TLS (HTTPS on 443) — only used with docker-compose.prod.yml ---
# Uncomment the next line on prod to terminate TLS in the web container and
# redirect :80 -> :443. Then deploy as usual: docker compose up -d --build.
# COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml
#
# Host dir holding the corporate-CA cert. Must contain:
#   fullchain.crt  (server cert + intermediate CA chain, concatenated)
#   server.key     (private key; chmod 600)
# CERTS_DIR_HOST=/data/cafeteria/certs
