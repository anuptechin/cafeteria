# Local Postgres (dedicated app user)
DATABASE_URL=postgres://canteen_app:CHANGE_ME@localhost:5432/canteen
PGHOST=localhost
PGPORT=5432
PGUSER=canteen_app
PGPASSWORD=CHANGE_ME
PGDATABASE=canteen
PORT=4000
FACES_DIR=./server/faces
APP_TZ=Asia/Kolkata

# Auth — session signing key + super admin bootstrap (super admin can never be deleted)
JWT_SECRET=replace-with-a-long-random-string
SUPER_ADMIN_USER=ambuj.kumar@ddecor.com
SUPER_ADMIN_NAME=Ambuj Kumar
SUPER_ADMIN_PASSWORD=CHANGE_ME

# --- Docker Compose only (containers talk over the internal 'db' network) ---
# DB host is 'db' (compose service name); URL-encode special chars in the password (@ -> %40).
COMPOSE_DATABASE_URL=postgres://canteen_app:CHANGE_ME@db:5432/canteen
SIMULATE=true
